        <!-- PAGE : CONTACT -->
        <section id="contact" class="page wrapper" data-x="14500" data-y="5250" data-rotate="90" data-scale="2">

            <!-- PAGE TITLE -->
            <h2 class="caption"><span>CONTACT</span></h2>

            <div class="iscroll-wrapper">
                <div class="scroller">

                    <!--row-->
                    <div class="row">

                        <!--column 7/12-->
                        <div class="map span7">
                            <h3>{{ site.maps.label }}</h3>
                            <img src="images/contact_map.jpg" alt="Map">
                        </div>
                        <!--column 7/12-->


                        <!--column 5/12-->
                        <div class="span5">

                            <h3>Drop me a line!</h3>

                            <!--CONTACT FORM-->
                            <form id="contact-form" name="contact" action="/" method="post" data-netlify="true" class="validate-form">
                                <input type="hidden" name="form-name" value="contact">
                                <fieldset>

                                    <!-- personal info -->
                                    <ul class="personal-info contact-form">
                                        <li><label class="title" for="name">NAME</label><input class="text required" id="name" name="name" type="text" placeholder="What is your name?"></li>
                                        <li><label class="title" for="email">E-MAIL</label><input class="text required email" id="email" name="email" type="text" placeholder="So i can get back to you."></li>
                                        <li><label class="title" for="message">MESSAGE</label><textarea class="text required" id="message" name="message" placeholder="And your message to me..."></textarea></li>
                                        <li class="submit-area">
                                            <button type="submit" class="btn-send">SEND</button>
                                            <input type="hidden" name="submitted" id="submitted" value="true">
                                            <span class="icon">&#194;</span>
                                        </li>
                                    </ul>
                                    <!-- personal info -->

                                </fieldset>
                            </form>
                            <!--CONTACT FORM-->

                        </div>
                        <!--column 5/12-->

                    </div>
                    <!--row-->

                </div>
                <!--end scroller-->
            </div>
            <!--iscroll-wrapper-->

        </section>
        <!-- PAGE : CONTACT -->
